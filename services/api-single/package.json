{
  "name": "@services/api-single",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#*": {
      "development": "./src/*",
      "types": "./src/*",
      "production": "./src/*",
      "default": "./src/*"
    }
  },
  "scripts": {
    "dev": "node --watch --env-file=../../.env --experimental-strip-types ./src/bin/server.ts",
    "start": "node ./dist/bin/server.js",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo",
    "db": "node --experimental-strip-types ./src/db/cli.ts",
    "db:migrate": "node --experimental-strip-types ./src/db/cli.ts migrate",
    "db:rollback": "node --experimental-strip-types ./src/db/cli.ts rollback",
    "db:create-migration": "node --experimental-strip-types ./src/db/cli.ts create"
  },
  "dependencies": {
    "@fastify/awilix": "^8.2.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@kit/config": "workspace:*",
    "@kit/core": "workspace:*",
    "@kit/db": "workspace:*",
    "@kit/errors": "workspace:*",
    "@kit/schemas": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "awilix": "^13.0.3",
    "citty": "^0.2.2",
    "fastify": "^5.8.4",
    "kysely": "^0.28.16",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@kit/eslint-config": "workspace:*",
    "@kit/test": "workspace:*",
    "@kit/ts-config": "workspace:*",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "kysely-pglite": "^0.6.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
