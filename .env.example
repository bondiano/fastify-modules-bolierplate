# Copy this file to `.env` and adjust as needed.
#   cp .env.example .env
#
# The ports below match the `docker-compose.yml` port mappings
# (Postgres 5433:5432, Redis 6380:6379), so `docker compose up -d`
# then `pnpm dev` works out of the box.

# ---- Application (base config, @kit/config) ----
ENVIRONMENT=development
LOG_LEVEL=debug
HOST=0.0.0.0
PORT=3000
APP_NAME=fastify-saas-kit
APP_VERSION=0.0.0

# ---- Database (@kit/db) ----
DATABASE_URL=postgresql://saaskit:saaskit@localhost:5433/saaskit_dev
DATABASE_MAX_CONNECTIONS=10
DATABASE_LOG_QUERIES=false

# ---- Redis / background jobs (@kit/jobs) ----
REDIS_URL=redis://localhost:6380

# ---- Auth (@kit/auth) ----
# JWT_SECRET must be at least 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-me-in-production-minimum-32-chars
JWT_ISSUER=fastify-saas-kit
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=14d

# ---- CORS (services/api) ----
CORS_ORIGINS=*
