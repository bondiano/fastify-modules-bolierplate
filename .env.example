# Application
ENVIRONMENT=development
LOG_LEVEL=debug
HOST=0.0.0.0
PORT=3000
APP_NAME=fastify-saas-kit
APP_VERSION=0.0.0

# Database
DATABASE_URL=postgresql://saaskit:saaskit@localhost:5432/saaskit_dev
DATABASE_MAX_CONNECTIONS=10
DATABASE_LOG_QUERIES=false

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-minimum-32-chars
JWT_ISSUER=fastify-saas-kit
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=14d

# CORS
CORS_ORIGINS=*
