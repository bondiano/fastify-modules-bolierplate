{
  "name": "@kit/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./password": {
      "types": "./dist/password.d.ts",
      "import": "./dist/password.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./token-utilities": {
      "types": "./dist/token-utilities.d.ts",
      "import": "./dist/token-utilities.js"
    },
    "./service": {
      "types": "./dist/auth.service.d.ts",
      "import": "./dist/auth.service.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js"
    },
    "./templates/password-reset": {
      "types": "./dist/templates/password-reset.d.ts",
      "import": "./dist/templates/password-reset.js"
    },
    "./templates/email-verification": {
      "types": "./dist/templates/email-verification.d.ts",
      "import": "./dist/templates/email-verification.js"
    },
    "./templates/otp": {
      "types": "./dist/templates/otp.d.ts",
      "import": "./dist/templates/otp.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@kit/core": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "awilix": "^13.0.3",
    "argon2": "^0.44.0",
    "fastify-plugin": "^5.1.0",
    "jose": "^6.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:*",
    "@kit/ts-config": "workspace:*",
    "@types/node": "^25.6.0",
    "fastify": "^5.8.4",
    "pino": "^10.3.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "fastify": "^5.0.0",
    "pino": "^9.0.0 || ^10.0.0"
  }
}
