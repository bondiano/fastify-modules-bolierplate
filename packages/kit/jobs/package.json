{
  "name": "@kit/jobs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@bull-board/api": "^6.21.0",
    "@bull-board/fastify": "^6.21.0",
    "bullmq": "^5.73.4",
    "fast-glob": "^3.3.3",
    "fastify-plugin": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:*",
    "@kit/ts-config": "workspace:*",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "fastify": "^5.0.0",
    "ioredis": "^5.0.0",
    "pino": "^9.0.0 || ^10.0.0"
  }
}
