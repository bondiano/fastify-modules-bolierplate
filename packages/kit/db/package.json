{
  "name": "@kit/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./repository": {
      "types": "./dist/runtime/repository.d.ts",
      "import": "./dist/runtime/repository.js"
    },
    "./transaction": {
      "types": "./dist/runtime/transaction.d.ts",
      "import": "./dist/runtime/transaction.js"
    },
    "./errors": {
      "types": "./dist/runtime/errors.d.ts",
      "import": "./dist/runtime/errors.js"
    },
    "./migrator": {
      "types": "./dist/cli/migrator.d.ts",
      "import": "./dist/cli/migrator.js"
    },
    "./config": {
      "types": "./dist/runtime/config.d.ts",
      "import": "./dist/runtime/config.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@kit/core": "workspace:*",
    "awilix": "^13.0.3",
    "kysely": "^0.28.16",
    "pg": "^8.20.0",
    "pg-cursor": "^2.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@kit/eslint-config": "workspace:*",
    "@kit/ts-config": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/pg-cursor": "^2.7.2",
    "pino": "^10.3.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "pino": "^9.0.0 || ^10.0.0"
  }
}
