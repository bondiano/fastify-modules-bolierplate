{
  "name": "fastify-saas-kit",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate": "node --experimental-strip-types --no-warnings=ExperimentalWarning ./tools/generators/src/cli.ts"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "prettier": "^3.5.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2"
  }
}
